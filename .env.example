# ============================================================================
# makeup-site — Environment variables
# Copia este archivo a .env y rellena los valores
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (Docker local)
# ----------------------------------------------------------------------------
DATABASE_URL="mysql://makeup:makeup@localhost:3306/makeup_dev"

# En Hostinger prod será algo como:
# DATABASE_URL="mysql://u123456_admin:password@localhost:3306/u123456_makeup"

# ----------------------------------------------------------------------------
# AUTH
# ----------------------------------------------------------------------------
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-en-produccion-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ----------------------------------------------------------------------------
# APP
# ----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ----------------------------------------------------------------------------
# SMTP (Email)
# Para dev puedes usar Mailtrap (https://mailtrap.io) o Gmail con App Password
# Para prod: Mailgun / Resend / SMTP del hosting
# ----------------------------------------------------------------------------
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="noreply@radiant-beauty.com"
SMTP_FROM_NAME="Radiant Beauty"

# ----------------------------------------------------------------------------
# MAGIC LINK (clientes)
# ----------------------------------------------------------------------------
MAGIC_LINK_EXPIRES_MIN="30"

# ----------------------------------------------------------------------------
# CRON (recordatorios)
# Token secreto para proteger endpoints de cron
# ----------------------------------------------------------------------------
CRON_SECRET="cambia-esto-en-produccion"

# ----------------------------------------------------------------------------
# UPLOADS
# ----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB="10"
ALLOWED_UPLOAD_TYPES="image/jpeg,image/png,image/webp,image/avif"

# ----------------------------------------------------------------------------
# LOG
# ----------------------------------------------------------------------------
LOG_LEVEL="info"